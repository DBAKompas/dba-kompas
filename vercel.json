{
  "regions": ["fra1"],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.dbakompas.nl" }],
      "destination": "https://dbakompas.nl/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/monthly-digest",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/news/refresh",
      "schedule": "0 7 * * *"
    }
  ]
}
